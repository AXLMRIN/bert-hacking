{
    "datasets":[
        {
            "filepath-train": "./data/ideology_news-stratified_year_balanced.csv",
            "name": "ideology_news",
            "text_col": "content",
            "label_col": "bias_text",
            "id_col": "ID",
            "filepath-predict": "./data/ideology_news-dataset_for_inference.csv"
        }
    ],
    "data-hyperparameters":{
        "N_annotated": [
            500, 
            1000, 
            1500, 
            2000
        ],
        "splits_ratio": [
            [80, 10, 10],
            [70, 15, 15]
        ]
    },
    "model-hyperparameters":{
        "model_name": [
            "google-bert/bert-base-uncased",
            "FacebookAI/xlm-roberta-base",
            "intfloat/multilingual-e5-large",
            "jhu-clsp/mmBERT-base",
            "google-bert/bert-base-multilingual-cased"
        ],
        "learning_rate":[
            5e-4,
            1e-4,
            1e-5, 
            2e-5, 
            5e-5
        ],
        "weight_decay":[
            0.0,
            0.01,
            0.001,
            0.05
        ]
    }
}